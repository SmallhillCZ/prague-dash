{
  "name": "smallhill-skeleton-nestjs",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "node dist/main",
    "start:dev": "npm run dev",
    "dev": "nest start --watch --debug --preserveWatchOutput",
    "build": "nest build",
    "cli": "node dist/main-cli.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "golemio:generate-sdk": "openapi-sdk -i https://api.golemio.cz/docs/static/output-gateway/openapi.json -o src/golemio/sdk",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli -d ./src/database/data-source.ts",
    "migrations:generate": "npm run typeorm migration:generate ./src/database/migrations/$npm_config_name",
    "migrations:create": "npm run typeorm migration:create ./src/database/migrations/$npm_config_name",
    "migrations:run": "npm run typeorm migration:run",
    "migrations:revert": "npm run typeorm migration:revert",
    "migrations:drop-schema": "npm run typeorm schema:drop",
    "migrations:reset": "npm run migrations:drop-schema && npm run migrations:run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.7",
    "@nestjs/core": "^11.1.7",
    "@nestjs/platform-express": "^11.1.7",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "golemio-sdk": "^2.0.40",
    "hbs": "^4.2.0",
    "nest-commander": "^3.20.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@smallhillcz/openapi-sdk": "^2.1.0",
    "@types/cron": "^2.4.3",
    "@types/express": "^5.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/luxon": "^3.7.1",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.9.1",
    "gtfs-types": "^5.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
